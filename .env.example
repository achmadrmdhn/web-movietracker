# Local development example environment variables
# Copy this file to `.env` and replace the values with your real keys.

# TMDB (frontend search) - safe for client-side read-only use
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Supabase (frontend) - only use the anon public key in the browser
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# If you need server-side privileged access (do NOT commit or expose):
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
